---
layout: null
lang: en
permalink: /en/feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>AI WhatChelin Daily</title>
  <link href="{{ site.url }}{{ site.baseurl }}/en/feed.xml" rel="self"/>
  <link href="{{ site.url }}{{ site.baseurl }}/en/"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}{{ site.baseurl }}/en/</id>
  <author>
    <name>AI WhatChelin</name>
  </author>
  {% assign en_posts = site.posts | where: "lang", "en" %}
  {% for post in en_posts limit:20 %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ site.baseurl }}{{ post.url }}"/>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ site.url }}{{ site.baseurl }}{{ post.url }}</id>
    <content type="html">{{ post.content | xml_escape }}</content>
    <summary>{{ post.excerpt | strip_html | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
