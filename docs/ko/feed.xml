---
layout: null
lang: ko
permalink: /ko/feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.i18n.ko.title | xml_escape }}</title>
  <link href="{{ site.url }}{{ site.baseurl }}/ko/feed.xml" rel="self"/>
  <link href="{{ site.url }}{{ site.baseurl }}/ko/"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}{{ site.baseurl }}/ko/</id>
  <author>
    <name>AI 뭐슐랭</name>
  </author>
  {% assign ko_posts = site.posts | where: "lang", "ko" %}
  {% if ko_posts.size > 0 %}
    {% for post in ko_posts limit:20 %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ site.baseurl }}{{ post.url }}"/>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ site.url }}{{ site.baseurl }}{{ post.url }}</id>
    <content type="html">{{ post.content | xml_escape }}</content>
    <summary>{{ post.excerpt | strip_html | xml_escape }}</summary>
  </entry>
    {% endfor %}
  {% else %}
    {% for post in site.posts limit:20 %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ site.baseurl }}{{ post.url }}"/>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ site.url }}{{ site.baseurl }}{{ post.url }}</id>
    <content type="html">{{ post.content | xml_escape }}</content>
    <summary>{{ post.excerpt | strip_html | xml_escape }}</summary>
  </entry>
    {% endfor %}
  {% endif %}
</feed>
